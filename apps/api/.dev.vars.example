APP_SECRET=replace-with-32+-chars-secret
WEBAUTHN_RP_NAME=Agentic Wallet MVP
SIM_API_KEY=replace-with-sim-api-key
# Optional: testnet | comma-separated chain ids (e.g. 1,8453,137 or 11155111,84532)
PORTFOLIO_CHAIN_IDS=11155111,84532
WEBAUTHN_REQUIRE_UV=false
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/replace
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/replace
BNB_RPC_URL=https://bnb-mainnet.g.alchemy.com/v2/replace
# Optional, defaults to SDK default MEE version
BICONOMY_MEE_VERSION=2.3.0

# Optional LLM integration (Phase 1 content/recommendation generation)
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=replace-with-llm-api-key

# Optional Bitget Wallet ToB API override (defaults to built-in public demo key/secret)
BGW_API_KEY=
BGW_API_SECRET=
